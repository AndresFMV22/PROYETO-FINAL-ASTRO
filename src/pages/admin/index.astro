---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Dashboard">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8 animate-fade-in">
    <div class="glass-card p-5">
      <div class="flex items-center gap-3 mb-2">
        <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center" style="color: #a78bfa;">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
        </div>
        <h3 class="text-white/50 text-xs font-medium uppercase tracking-wider">Total Productos</h3>
      </div>
      <p class="text-3xl font-bold text-gradient-primary" id="stat-products">-</p>
    </div>
    <div class="glass-card p-5">
      <div class="flex items-center gap-3 mb-2">
        <div class="w-9 h-9 rounded-lg bg-accent/10 flex items-center justify-center" style="color: #f472b6;">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <h3 class="text-white/50 text-xs font-medium uppercase tracking-wider">Total Ventas</h3>
      </div>
      <p class="text-3xl font-bold text-gradient-primary" id="stat-sales">$0.00</p>
    </div>
    <div class="glass-card p-5">
      <div class="flex items-center gap-3 mb-2">
        <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center" style="color: #a78bfa;">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <h3 class="text-white/50 text-xs font-medium uppercase tracking-wider">Pedidos</h3>
      </div>
      <p class="text-3xl font-bold text-gradient-primary" id="stat-orders">0</p>
    </div>
  </div>

  <div id="recent-activity" class="glass-card p-6">
    <h3 class="text-white/60 text-xs font-medium uppercase tracking-wider mb-4">Actividad Reciente</h3>
    <div id="activity-list" class="space-y-3">
      <p class="text-white/20 text-sm text-center py-8">No hay actividad reciente.</p>
    </div>
  </div>

  <script>
    import { createBrowserClient } from '@supabase/ssr';
    import { getOrders } from '../../lib/cart';

    const supabase = createBrowserClient(
      import.meta.env.PUBLIC_SUPABASE_URL,
      import.meta.env.PUBLIC_SUPABASE_ANON_KEY
    );

    async function fetchStats() {
      const { count } = await supabase.from('products').select('*', { count: 'exact', head: true });
      const el = document.getElementById('stat-products');
      if (el && count !== null) el.textContent = count.toString();
    }

    function loadOrders() {
      const orders = getOrders();
      const salesEl = document.getElementById('stat-sales');
      const ordersEl = document.getElementById('stat-orders');
      const activityEl = document.getElementById('activity-list');

      if (orders.length === 0) {
        if (salesEl) salesEl.textContent = '$0.00';
        if (ordersEl) ordersEl.textContent = '0';
        if (activityEl) activityEl.innerHTML = '<p class="text-white/20 text-sm text-center py-8">No hay actividad reciente.</p>';
        return;
      }

      const totalSales = orders.reduce((sum, o) => sum + o.total, 0);
      if (salesEl) salesEl.textContent = `$${totalSales.toFixed(2)}`;
      if (ordersEl) ordersEl.textContent = orders.length.toString();

      if (activityEl) {
        activityEl.innerHTML = orders.map(o => {
          const date = new Date(o.date);
          const dateStr = date.toLocaleDateString('es-CO', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' });
          const itemsSummary = o.items.map(i => `${i.title} × ${i.quantity}`).join(', ');
          return `
            <div class="flex items-start gap-3 p-3 rounded-xl bg-white/[0.02] border border-white/[0.04]">
              <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-primary to-accent flex items-center justify-center shrink-0 shadow-lg shadow-primary/20">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-white/80">${o.cardholderName}</p>
                <p class="text-xs text-white/40 truncate">${itemsSummary}</p>
                <div class="flex items-center gap-3 mt-1">
                  <span class="text-xs font-semibold text-gradient-primary">$${o.total.toFixed(2)}</span>
                  <span class="text-[10px] text-white/25">${dateStr}</span>
                </div>
              </div>
            </div>
          `;
        }).join('');
      }
    }

    fetchStats();
    loadOrders();
    addEventListener('orders-update', loadOrders);
  </script>
</AdminLayout>
