---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Pedidos">
  <div class="mb-5">
    <p class="text-white/40 text-xs">Gestiona los pedidos de tus clientes</p>
  </div>

  <div class="glass-strong rounded-xl overflow-hidden">
    <table class="w-full text-left border-collapse min-w-[800px]">
      <thead>
        <tr class="border-b border-white/[0.04] text-white/30 text-xs">
          <th class="p-3 font-medium">Pedido</th>
          <th class="p-3 font-medium">Cliente</th>
          <th class="p-3 font-medium">Productos</th>
          <th class="p-3 font-medium text-right">Total</th>
          <th class="p-3 font-medium text-center">Estado</th>
          <th class="p-3 font-medium text-right">Fecha</th>
        </tr>
      </thead>
      <tbody id="orders-body" class="text-sm divide-y divide-white/[0.03]">
        <tr>
          <td colspan="6" class="p-10 text-center text-white/25">Cargando pedidos...</td>
        </tr>
      </tbody>
    </table>
  </div>

  <script>
    import { getOrders } from '../../../lib/cart';

    function loadOrders() {
      const orders = getOrders();
      const tbody = document.getElementById('orders-body');
      if (!tbody) return;

      if (orders.length === 0) {
        tbody.innerHTML = `<tr><td colspan="6" class="p-10 text-center text-white/30">No hay pedidos registrados.</td></tr>`;
        return;
      }

      const statuses = ['Confirmado', 'En preparacion', 'Enviado', 'Entregado'];

      tbody.innerHTML = orders.map((o, idx) => {
        const date = new Date(o.date);
        const dateStr = date.toLocaleDateString('es-CO', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
        const itemsSummary = o.items.map(i => `${i.title} × ${i.quantity}`).join(', ');
        const status = statuses[Math.min(idx, statuses.length - 1)];
        const statusColor = idx === 0 ? 'bg-amber-500/15 text-amber-400 border-amber-500/20'
          : idx === 1 ? 'bg-blue-500/15 text-blue-400 border-blue-500/20'
          : idx === 2 ? 'bg-purple-500/15 text-purple-400 border-purple-500/20'
          : 'bg-green-500/15 text-green-400 border-green-500/20';
        return `
          <tr class="hover:bg-white/[0.015] transition-colors">
            <td class="p-3 font-mono text-xs text-white/50">#${o.id.substring(0, 8)}</td>
            <td class="p-3 font-medium text-white/70">${o.cardholderName}</td>
            <td class="p-3 text-xs text-white/50 max-w-[200px] truncate" title="${itemsSummary}">${itemsSummary}</td>
            <td class="p-3 font-semibold text-white text-right">$${o.total.toFixed(2)}</td>
            <td class="p-3 text-center">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider border ${statusColor}">${status}</span>
            </td>
            <td class="p-3 text-right text-xs text-white/30 whitespace-nowrap">${dateStr}</td>
          </tr>
        `;
      }).join('');
    }

    loadOrders();
    addEventListener('orders-update', loadOrders);
  </script>
</AdminLayout>
