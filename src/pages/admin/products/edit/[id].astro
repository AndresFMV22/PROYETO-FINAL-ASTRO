---
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { getSupabase } from '../../../../lib/supabase';

const { id } = Astro.params;

const FIELDS = 'id, title, price, description, image_url, category, stock, created_at';
const supabase = getSupabase(Astro.cookies);
const { data: product, error } = await supabase.from('products').select(FIELDS).eq('id', id).single();

if (error || !product) {
  return Astro.redirect('/admin/products');
}
---

<AdminLayout title="Editar Producto">
  <div class="max-w-2xl glass-strong rounded-xl p-6 animate-slide-up">
    <form id="edit-product-form" class="space-y-5">
      <input type="hidden" id="product-id" value={product.id} />
      <input type="hidden" id="current-image-url" value={product.image_url || ''} />

      <div class="space-y-1.5">
        <label class="block text-xs font-medium text-white/40">Título del Producto</label>
        <input type="text" id="title" required class="input-glass" value={product.title} />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div class="space-y-1.5">
          <label class="block text-xs font-medium text-white/40">Precio ($)</label>
          <div class="relative">
            <span class="absolute left-3.5 top-2.5 text-white/25 text-sm">$</span>
            <input type="number" id="price" step="0.01" required class="input-glass pl-7" value={product.price} />
          </div>
        </div>

        <div class="space-y-1.5">
          <label class="block text-xs font-medium text-white/40">Categoría</label>
          <select id="category" required class="select-glass">
            <option value="Electrónica" selected={product.category === 'Electrónica'}>Electrónica</option>
            <option value="Ropa" selected={product.category === 'Ropa'}>Ropa</option>
            <option value="Hogar" selected={product.category === 'Hogar'}>Hogar</option>
            <option value="Deportes" selected={product.category === 'Deportes'}>Deportes</option>
          </select>
        </div>
      </div>

      <div class="space-y-1.5">
        <label class="block text-xs font-medium text-white/40">Descripción</label>
        <textarea id="description" rows="3" class="input-glass resize-none">{product.description}</textarea>
      </div>

      <div class="space-y-1.5">
        <label class="block text-xs font-medium text-white/40">Stock</label>
        <input type="number" id="stock" min="0" step="1" required class="input-glass" value={product.stock ?? 10} />
      </div>

      <div class="space-y-1.5">
        <label class="block text-xs font-medium text-white/40">Imagen (dejar vacío para conservar)</label>
        <div class="border border-dashed border-white/[0.06] rounded-xl p-5 text-center hover:bg-white/[0.01] transition-colors">
          <input type="file" id="image" accept="image/*" class="w-full text-xs text-white/30 file:mr-3 file:py-1.5 file:px-4 file:rounded-lg file:border-0 file:text-xs file:font-medium file:bg-primary/15 file:text-primary-light hover:file:bg-primary/25 transition-all cursor-pointer" />
        </div>
        {product.image_url && (
          <div class="flex items-center gap-3 bg-white/[0.03] p-2.5 rounded-lg border border-white/[0.04]">
            <p class="text-xs text-white/30">Actual:</p>
            <img src={product.image_url} alt="Actual" class="h-10 w-10 object-cover rounded-lg border border-white/[0.06]" />
          </div>
        )}
      </div>

      <div class="flex flex-col-reverse sm:flex-row justify-end gap-2.5 pt-4 border-t border-white/[0.06]">
        <a href="/admin/products" class="btn-glass px-5 py-2 rounded-lg text-xs text-center">Cancelar</a>
        <button type="submit" id="submit-btn" class="btn-primary px-5 py-2 rounded-lg text-xs flex justify-center items-center gap-1.5 disabled:opacity-50">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
          Actualizar Producto
        </button>
      </div>
      <div id="status-msg" class="text-xs p-3 rounded-lg hidden border"></div>
    </form>
  </div>

  <script>
    import { createBrowserClient } from '@supabase/ssr';
    const supabase = createBrowserClient(
      import.meta.env.PUBLIC_SUPABASE_URL,
      import.meta.env.PUBLIC_SUPABASE_ANON_KEY
    );

    const form = document.getElementById('edit-product-form');
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const statusMsg = document.getElementById('status-msg');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<svg class="animate-spin -ml-1 mr-1.5 h-3.5 w-3.5 text-white inline" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Guardando...';
      }

      if (statusMsg) statusMsg.classList.add('hidden');

      const id = (document.getElementById('product-id') as HTMLInputElement).value;
      const title = (document.getElementById('title') as HTMLInputElement).value;
      const price = parseFloat((document.getElementById('price') as HTMLInputElement).value);
      const category = (document.getElementById('category') as HTMLSelectElement).value;
      const description = (document.getElementById('description') as HTMLTextAreaElement).value;
      const stock = parseInt((document.getElementById('stock') as HTMLInputElement).value, 10) || 0;
      const imageFile = (document.getElementById('image') as HTMLInputElement).files?.[0];
      let imageUrl = (document.getElementById('current-image-url') as HTMLInputElement).value || null;

      if (imageFile) {
        const fileExt = imageFile.name.split('.').pop();
        const fileName = `${Date.now()}-${Math.random().toString(36).substring(2, 9)}.${fileExt}`;

        const { error: uploadError } = await supabase.storage.from('products').upload(fileName, imageFile);

        if (uploadError) {
          if (statusMsg) {
            statusMsg.textContent = `Error subiendo imagen: ${uploadError.message}`;
            statusMsg.className = 'text-xs p-3 rounded-lg bg-red-500/10 text-red-400 border border-red-500/15';
            statusMsg.classList.remove('hidden');
          }
          if (submitBtn) { submitBtn.disabled = false; submitBtn.innerHTML = 'Actualizar Producto'; }
          return;
        }

        const { data: { publicUrl } } = supabase.storage.from('products').getPublicUrl(fileName);
        imageUrl = publicUrl;
      }

      const { error: updateError } = await supabase.from('products').update({
        title, price, category, description, stock, image_url: imageUrl
      }).eq('id', id);

      if (updateError) {
        if (statusMsg) {
          statusMsg.textContent = `Error: ${updateError.message}`;
          statusMsg.className = 'text-xs p-3 rounded-lg bg-red-500/10 text-red-400 border border-red-500/15';
          statusMsg.classList.remove('hidden');
        }
        if (submitBtn) { submitBtn.disabled = false; submitBtn.innerHTML = 'Actualizar Producto'; }
      } else {
        if (statusMsg) {
          statusMsg.innerHTML = 'Producto actualizado exitosamente. Redirigiendo...';
          statusMsg.className = 'text-xs p-3 rounded-lg bg-green-500/10 text-green-400 border border-green-500/15 font-medium';
          statusMsg.classList.remove('hidden');
        }
        setTimeout(() => { window.location.href = '/admin/products'; }, 1500);
      }
    });
  </script>
</AdminLayout>
