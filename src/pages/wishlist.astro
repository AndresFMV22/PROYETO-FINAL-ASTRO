---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Mis Favoritos">
  <div class="max-w-4xl mx-auto py-8 animate-fade-in">
    <div class="flex items-center justify-between mb-8">
      <h1 class="text-2xl font-bold text-white/90">Mis Favoritos</h1>
      <span id="wishlist-count" class="text-xs text-white/30"></span>
    </div>

    <div id="wishlist-empty" class="glass-card p-14 text-center hidden">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-white/[0.03] mb-5">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </div>
      <h3 class="text-lg font-semibold text-white/60 mb-1">No tienes favoritos</h3>
      <p class="text-white/30 text-sm mb-6">Guarda productos que te gusten para despues.</p>
      <a href="/" class="btn-primary px-5 py-2.5 rounded-lg text-sm">Explorar productos</a>
    </div>

    <div id="wishlist-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 hidden"></div>
  </div>

  <script>
    import { getWishlistItems, removeFromWishlist } from '../lib/wishlist';

    function render() {
      const items = getWishlistItems();
      const emptyEl = document.getElementById('wishlist-empty');
      const gridEl = document.getElementById('wishlist-grid');
      const countEl = document.getElementById('wishlist-count');

      if (countEl) countEl.textContent = `${items.length} producto${items.length !== 1 ? 's' : ''}`;

      if (items.length === 0) {
        emptyEl?.classList.remove('hidden');
        gridEl?.classList.add('hidden');
        return;
      }

      emptyEl?.classList.add('hidden');
      gridEl?.classList.remove('hidden');

      if (gridEl) {
        gridEl.innerHTML = items.map(item => `
          <div class="glass-card overflow-hidden group">
            <a href="/product/${item.id}" class="block aspect-square overflow-hidden">
              ${item.imageUrl
                ? `<img src="${item.imageUrl}" alt="${item.title}" class="w-full h-full object-cover transition-all duration-500 group-hover:scale-105"/>`
                : '<div class="w-full h-full flex items-center justify-center text-white/10"><svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg></div>'}
            </a>
            <div class="p-4">
              <a href="/product/${item.id}" class="text-sm font-medium text-white/80 hover:text-white transition-colors truncate block">${item.title}</a>
              <p class="text-sm font-semibold text-gradient-primary mt-1">$${item.price.toFixed(2)}</p>
              <button onclick="removeWishlist('${item.id}')" class="btn-glass px-3 py-1 rounded-lg text-[10px] mt-3 w-full text-red-400/60 hover:text-red-400">Quitar</button>
            </div>
          </div>
        `).join('');
      }
    }

    (window as any).removeWishlist = (id: string) => {
      removeFromWishlist(id);
      render();
    };

    addEventListener('wishlist-update', render);
    render();
  </script>
</Layout>
