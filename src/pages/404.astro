---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pagina no encontrada">
  <div class="min-h-[70vh] flex items-center justify-center py-12">
    <div class="text-center animate-fade-in">
      <div class="text-8xl font-black text-gradient mb-4">404</div>
      <h1 class="text-2xl font-bold text-white/90 mb-2">Pagina no encontrada</h1>
      <p class="text-white/40 text-sm mb-8 max-w-md mx-auto">
        La pagina que buscas no existe o fue movida.
      </p>
      <a href="/" class="btn-primary px-6 py-2.5 rounded-lg text-sm">Volver al inicio</a>
    </div>
  </div>
</Layout>
