---
import Layout from '../../layouts/Layout.astro';
import { getSupabase } from '../../lib/supabase';

const { id } = Astro.params;

const supabase = getSupabase(Astro.cookies);
const { data: product, error } = await supabase.from('products').select('*').eq('id', id).single();

if (error || !product) {
  return Astro.redirect('/404');
}
---

<Layout title={product.title}>
  <div class="max-w-5xl mx-auto py-10 animate-fade-in">
    <a href="/" class="btn-glass px-4 py-2 rounded-xl text-sm text-white/60 hover:text-white inline-flex items-center gap-2 mb-8 transition-all">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      Volver al catálogo
    </a>

    <div class="glass-strong rounded-3xl overflow-hidden">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
        <div class="aspect-square overflow-hidden bg-black/20 relative">
          {product.image_url ? (
            <img src={product.image_url} alt={product.title} class="w-full h-full object-cover transition-all duration-1000 hover:scale-105" />
          ) : (
            <div class="w-full h-full flex items-center justify-center" style="color: rgba(255,255,255,0.15);">
              <svg xmlns="http://www.w3.org/2000/svg" width="96" height="96" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
            </div>
          )}
        </div>

        <div class="p-8 md:p-12 flex flex-col justify-center">
          <div class="tag mb-5 inline-block w-fit">
            {product.category}
          </div>

          <h1 class="text-3xl md:text-5xl font-extrabold text-white tracking-tight mb-4 leading-tight">
            {product.title}
          </h1>

          <p class="text-4xl md:text-5xl font-black text-gradient mb-8">
            ${parseFloat(product.price).toFixed(2)}
          </p>

          <div class="border-t border-white/10 pt-6 mb-8">
            <p class="text-white/60 text-lg leading-relaxed">
              {product.description || 'Sin descripción disponible para este producto.'}
            </p>
          </div>

          <button class="btn-primary py-4 px-8 rounded-xl font-bold text-lg shadow-lg shadow-indigo-500/30 transition-all hover:-translate-y-1 hover:shadow-xl w-full md:w-auto flex items-center justify-center gap-3 active:scale-95">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
            Añadir al carrito
          </button>
        </div>
      </div>
    </div>
  </div>
</Layout>
