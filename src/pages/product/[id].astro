---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getSupabase } from '../../lib/supabase';

const { id } = Astro.params;

const supabase = getSupabase(Astro.cookies);
const { data: product } = await supabase.from('products').select('*').eq('id', id).single();

if (!product) return Astro.redirect('/404');

const { data: related } = await supabase
  .from('products')
  .select('*')
  .eq('category', product.category)
  .neq('id', product.id)
  .limit(4);

const stock = product.stock ?? Math.floor(Math.random() * 15) + 1;
const lowStock = stock <= 3;
const outOfStock = stock === 0;
const outOfStockAttr = outOfStock;

---

<Layout title={product.title}>
  <div class="max-w-5xl mx-auto py-8 animate-fade-in">
    <a href="/" class="btn-glass px-3.5 py-1.5 rounded-lg text-xs inline-flex items-center gap-1.5 mb-6 transition-all">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      Volver al catalogo
    </a>

    <div class="glass-strong rounded-2xl overflow-hidden mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
        <div class="aspect-square overflow-hidden bg-black/20 relative">
          {product.image_url ? (
            <img src={product.image_url} alt={product.title} class="w-full h-full object-cover transition-all duration-700 hover:scale-105" />
          ) : (
            <div class="w-full h-full flex items-center justify-center" style="color: rgba(255,255,255,0.1);">
              <svg xmlns="http://www.w3.org/2000/svg" width="72" height="72" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
            </div>
          )}
          <button id="wishlist-btn" class="absolute top-4 left-4 w-9 h-9 rounded-xl glass flex items-center justify-center transition-all hover:scale-110">
            <svg id="wishlist-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </button>
        </div>

        <div class="p-7 md:p-10 flex flex-col justify-center">
          <div class="flex items-center gap-3 mb-4">
            <span class="tag">{product.category}</span>
            <span id="stock-badge" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider"
              class:list={[
                outOfStock ? 'bg-red-500/15 text-red-400 border border-red-500/20' : lowStock ? 'bg-amber-500/15 text-amber-400 border border-amber-500/20' : 'bg-green-500/15 text-green-400 border border-green-500/20'
              ]}>
              {outOfStock ? 'Agotado' : lowStock ? `Quedan ${stock}` : 'En stock'}
            </span>
          </div>

          <div id="rating-display" class="flex items-center gap-2 mb-3"></div>

          <h1 class="text-2xl md:text-4xl font-bold text-white/90 tracking-tight mb-3 leading-tight">
            {product.title}
          </h1>

          <p class="text-3xl md:text-4xl font-bold text-gradient-primary mb-6">
            ${parseFloat(product.price).toFixed(2)}
          </p>

          <div class="border-t border-white/[0.06] pt-5 mb-6">
            <p class="text-white/50 text-sm leading-relaxed">
              {product.description || 'Sin descripcion disponible para este producto.'}
            </p>
          </div>

          <button id="add-to-cart-btn" class="btn-primary py-3 px-6 rounded-lg font-medium text-sm shadow-lg transition-all hover:-translate-y-0.5 w-full md:w-auto flex items-center justify-center gap-2 active:scale-95 disabled:opacity-40 disabled:hover:translate-y-0">
            <svg id="cart-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
            <span id="btn-text">{outOfStock ? 'Agotado' : 'Anadir al carrito'}</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Reviews -->
    <div class="glass-strong rounded-2xl p-6 mb-8">
      <h2 class="text-lg font-bold text-white/80 mb-6">Resenas</h2>

      <div id="review-form" class="mb-8 p-4 rounded-xl bg-white/[0.02] border border-white/[0.04]">
        <h3 class="text-sm font-medium text-white/70 mb-3">Escribe una resena</h3>
        <div id="star-selector" class="flex gap-1 mb-3"></div>
        <textarea id="review-comment" rows="2" class="input-glass mb-3" placeholder="Tu opinion..."></textarea>
        <button onclick="submitReview()" class="btn-primary px-4 py-2 rounded-lg text-xs">Enviar resena</button>
        <div id="review-msg" class="text-xs mt-2 hidden"></div>
      </div>

      <div id="reviews-list" class="space-y-4">
        <p class="text-white/20 text-sm text-center py-4">No hay resenas aun. Se el primero en opinar.</p>
      </div>
    </div>

    <!-- Related -->
    {related && related.length > 0 && (
      <div>
        <h2 class="text-lg font-bold text-white/80 mb-4">Productos relacionados</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {related.map(r => (
            <ProductCard id={r.id} title={r.title} price={r.price} imageUrl={r.image_url} category={r.category} stock={r.stock ?? 10} />
          ))}
        </div>
      </div>
    )}
  </div>

  <script is:inline>window.__productData = {JSON.stringify({ id: product.id, title: product.title, price: product.price, image_url: product.image_url, category: product.category })};window.__isOutOfStock = {outOfStockAttr};</script>

  <script>
    import { addItem } from '../../lib/cart';
    import { toggleItem, isInWishlist } from '../../lib/wishlist';
    import { addReview, getReviewsForProduct, getAverageRating } from '../../lib/reviews';
    import { getSession } from '../../lib/auth';

    const productData = window.__productData;
    const productId = productData.id;
    const productTitle = productData.title;
    const productPrice = productData.price;
    const productImage = productData.image_url || '';
    const productCategory = productData.category;
    const isOutOfStock = window.__isOutOfStock;

    let selectedStar = 0;

    // Star selector UI
    const starEl = document.getElementById('star-selector');
    if (starEl) {
      for (let i = 1; i <= 5; i++) {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'review-star text-white/20 hover:text-amber-400 transition-colors text-lg';
        btn.textContent = '\u2605';
        btn.dataset.val = i.toString();
        btn.onclick = () => {
          selectedStar = i;
          starEl.querySelectorAll('.review-star').forEach((s, idx) => {
            (s as HTMLElement).style.color = idx < i ? '#fbbf24' : 'rgba(255,255,255,0.2)';
          });
        };
        starEl.appendChild(btn);
      }
    }

    // Wishlist
    const wishlistBtn = document.getElementById('wishlist-btn');
    const wishlistIcon = document.getElementById('wishlist-icon');
    if (isInWishlist(productId)) {
      wishlistIcon?.setAttribute('fill', '#ec4899');
      wishlistIcon?.setAttribute('stroke', '#ec4899');
    }
    wishlistBtn?.addEventListener('click', () => {
      toggleItem({ id: productId, title: productTitle, price: productPrice, imageUrl: productImage, category: productCategory });
      const inWishlist = isInWishlist(productId);
      if (inWishlist) {
        wishlistIcon?.setAttribute('fill', '#ec4899');
        wishlistIcon?.setAttribute('stroke', '#ec4899');
      } else {
        wishlistIcon?.setAttribute('fill', 'none');
        wishlistIcon?.setAttribute('stroke', 'rgba(255,255,255,0.5)');
      }
    });

    // Add to cart
    const btn = document.getElementById('add-to-cart-btn') as HTMLButtonElement;
    const btnText = document.getElementById('btn-text');
    const cartIcon = document.getElementById('cart-icon');

    if (!isOutOfStock) {
      btn?.addEventListener('click', () => {
        addItem({ id: productId, title: productTitle, price: productPrice, imageUrl: productImage || null });
        if (btnText) btnText.textContent = '¡Agregado!';
        if (cartIcon) { cartIcon.innerHTML = '<path d="M20 6 9 17l-5-5"/>'; cartIcon.style.stroke = '#22c55e'; }
        btn.classList.add('!bg-green-500/20', '!border-green-500/30', '!text-green-400');
        setTimeout(() => {
          if (btnText) btnText.textContent = 'Anadir al carrito';
          if (cartIcon) { cartIcon.innerHTML = '<circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/>'; cartIcon.style.stroke = ''; }
          btn.classList.remove('!bg-green-500/20', '!border-green-500/30', '!text-green-400');
        }, 1500);
      });
    } else {
      btn.disabled = true;
    }

    // Rating display
    function renderRating() {
      const { average, count } = getAverageRating(productId);
      const display = document.getElementById('rating-display');
      if (display) {
        const full = Math.round(average);
        const stars = Array.from({length: 5}, (_, i) =>
          `<span class="text-sm ${i < full ? 'text-amber-400' : 'text-white/15'}">\u2605</span>`
        ).join('');
        const text = count > 0 ? `<span class="text-xs text-white/30">(${count} ${count === 1 ? 'resena' : 'resenas'})</span>` : '';
        display.innerHTML = stars + text;
      }
    }

    // Submit review
    (window as any).submitReview = () => {
      const session = getSession();
      if (selectedStar === 0) return;
      const comment = (document.getElementById('review-comment') as HTMLTextAreaElement).value.trim();
      if (!comment) return;
      const userName = session ? session.name : 'Usuario';
      addReview(productId, session?.id || 'guest', userName, selectedStar, comment);
      (document.getElementById('review-comment') as HTMLTextAreaElement).value = '';
      selectedStar = 0;
      document.querySelectorAll('.review-star').forEach(s => (s as HTMLElement).style.color = 'rgba(255,255,255,0.2)');
      const msg = document.getElementById('review-msg');
      if (msg) { msg.textContent = 'Resena enviada'; msg.className = 'text-xs mt-2 text-green-400'; msg.classList.remove('hidden'); }
      setTimeout(() => { if (msg) msg.classList.add('hidden'); }, 2000);
      loadReviews();
      renderRating();
    };

    // Load reviews
    function loadReviews() {
      const reviews = getReviewsForProduct(productId);
      const list = document.getElementById('reviews-list');
      if (!list) return;
      if (reviews.length === 0) {
        list.innerHTML = '<p class="text-white/20 text-sm text-center py-4">No hay resenas aun. Se el primero en opinar.</p>';
        return;
      }
      list.innerHTML = reviews.map(r => {
        const date = new Date(r.date);
        const stars = Array.from({length: 5}, (_, i) =>
          `<span class="text-xs ${i < r.rating ? 'text-amber-400' : 'text-white/10'}">\u2605</span>`
        ).join('');
        return `
          <div class="p-4 rounded-xl bg-white/[0.02] border border-white/[0.04]">
            <div class="flex items-center justify-between mb-1">
              <span class="text-sm font-medium text-white/70">${r.userName}</span>
              <span class="text-[10px] text-white/20">${date.toLocaleDateString('es-CO', { day: 'numeric', month: 'short' })}</span>
            </div>
            <div class="flex gap-0.5 mb-2">${stars}</div>
            <p class="text-sm text-white/50">${r.comment}</p>
          </div>
        `;
      }).join('');
    }

    renderRating();
    loadReviews();
  </script>
</Layout>
