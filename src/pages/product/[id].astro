---
import Layout from '../../layouts/Layout.astro';
import { getSupabase } from '../../lib/supabase';

const { id } = Astro.params;

const supabase = getSupabase(Astro.cookies);
const { data: product, error } = await supabase.from('products').select('*').eq('id', id).single();

if (error || !product) {
  return Astro.redirect('/404');
}
---

<Layout title={product.title}>
  <div class="max-w-5xl mx-auto py-8 animate-fade-in">
    <a href="/" class="btn-glass px-3.5 py-1.5 rounded-lg text-xs inline-flex items-center gap-1.5 mb-6 transition-all">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      Volver al catálogo
    </a>

    <div class="glass-strong rounded-2xl overflow-hidden">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
        <div class="aspect-square overflow-hidden bg-black/20 relative">
          {product.image_url ? (
            <img src={product.image_url} alt={product.title} class="w-full h-full object-cover transition-all duration-700 hover:scale-105" />
          ) : (
            <div class="w-full h-full flex items-center justify-center" style="color: rgba(255,255,255,0.1);">
              <svg xmlns="http://www.w3.org/2000/svg" width="72" height="72" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
            </div>
          )}
        </div>

        <div class="p-7 md:p-10 flex flex-col justify-center">
          <div class="tag mb-4 inline-block w-fit">
            {product.category}
          </div>

          <h1 class="text-2xl md:text-4xl font-bold text-white/90 tracking-tight mb-3 leading-tight">
            {product.title}
          </h1>

          <p class="text-3xl md:text-4xl font-bold text-gradient-primary mb-6">
            ${parseFloat(product.price).toFixed(2)}
          </p>

          <div class="border-t border-white/[0.06] pt-5 mb-6">
            <p class="text-white/50 text-sm leading-relaxed">
              {product.description || 'Sin descripción disponible para este producto.'}
            </p>
          </div>

          <button id="add-to-cart-btn" class="btn-primary py-3 px-6 rounded-lg font-medium text-sm shadow-lg transition-all hover:-translate-y-0.5 w-full md:w-auto flex items-center justify-center gap-2 active:scale-95" data-id={product.id} data-title={product.title} data-price={product.price} data-image={product.image_url || ''}>
            <svg id="cart-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
            <span id="btn-text">Añadir al carrito</span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { addItem } from '../../lib/cart';

    const btn = document.getElementById('add-to-cart-btn') as HTMLButtonElement;
    const btnText = document.getElementById('btn-text');
    const cartIcon = document.getElementById('cart-icon');

    btn?.addEventListener('click', () => {
      addItem({
        id: btn.dataset.id!,
        title: btn.dataset.title!,
        price: parseFloat(btn.dataset.price!),
        imageUrl: btn.dataset.image || null,
      });

      if (btnText) btnText.textContent = '¡Agregado!';
      if (cartIcon) {
        cartIcon.innerHTML = '<path d="M20 6L9 17l-5-5"/>';
        cartIcon.style.stroke = '#22c55e';
      }
      btn.classList.add('!bg-green-500/20', '!border-green-500/30', '!text-green-400', '!shadow-green-500/20');

      setTimeout(() => {
        if (btnText) btnText.textContent = 'Añadir al carrito';
        if (cartIcon) {
          cartIcon.innerHTML = '<circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/>';
          cartIcon.style.stroke = '';
        }
        btn.classList.remove('!bg-green-500/20', '!border-green-500/30', '!text-green-400', '!shadow-green-500/20');
      }, 1500);
    });
  </script>
</Layout>
