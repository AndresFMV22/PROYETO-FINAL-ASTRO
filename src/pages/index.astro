---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import { getSupabase } from '../lib/supabase';

const supabase = getSupabase(Astro.cookies);

const categoryParam = Astro.url.searchParams.get('category');
const searchParam = Astro.url.searchParams.get('search');
const pageParam = parseInt(Astro.url.searchParams.get('page') || '1', 10);
const page = Math.max(1, pageParam);
const perPage = 8;

let countQuery = supabase.from('products').select('*', { count: 'exact', head: true });
let dataQuery = supabase.from('products').select('*').order('created_at', { ascending: false });

if (categoryParam) {
  countQuery = countQuery.eq('category', categoryParam);
  dataQuery = dataQuery.eq('category', categoryParam);
}

if (searchParam) {
  countQuery = countQuery.ilike('title', `%${searchParam}%`);
  dataQuery = dataQuery.ilike('title', `%${searchParam}%`);
}

const { count: totalItems } = await countQuery;
const totalPages = Math.max(1, Math.ceil((totalItems || 0) / perPage));
const currentPage = Math.min(page, totalPages);
const offset = (currentPage - 1) * perPage;

const { data: products, error } = await dataQuery.range(offset, offset + perPage - 1);

const categories = ['Electrónica', 'Ropa', 'Hogar', 'Deportes'];
---

<Layout title="LiquidSky Store — Catálogo">
  <!-- Hero -->
  <div class="text-center py-16 animate-fade-in">
    <h1 class="text-5xl md:text-7xl font-extrabold text-gradient mb-6 leading-tight">
      Descubre lo <br class="hidden sm:block"/>Excepcional
    </h1>
    <p class="text-white/50 text-lg md:text-xl max-w-2xl mx-auto">
      Productos seleccionados con precisión para quienes buscan calidad y diseño.
    </p>
  </div>

  <!-- Search + Filters -->
  <div class="glass-strong rounded-2xl p-4 sm:p-6 mb-10 animate-slide-up flex flex-col sm:flex-row gap-4 items-stretch sm:items-center">
    <form method="GET" class="flex-1 flex gap-3 items-center" id="search-form">
      {categoryParam && <input type="hidden" name="category" value={categoryParam} />}
      <div class="relative flex-1">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-4 top-1/2 -translate-y-1/2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input
          type="text"
          name="search"
          value={searchParam || ''}
          placeholder="Buscar productos..."
          class="input-glass pl-12"
        />
      </div>
      <button type="submit" class="btn-primary px-6 py-3 rounded-xl text-sm whitespace-nowrap">
        Buscar
      </button>
      {(searchParam || categoryParam) && (
        <a href="/" class="btn-glass px-4 py-3 rounded-xl text-sm whitespace-nowrap text-white/70 hover:text-white">
          Limpiar
        </a>
      )}
    </form>
    <div class="flex gap-2 overflow-x-auto flex-wrap">
      <a href={searchParam ? `/?search=${searchParam}` : '/'} class={`px-4 py-2 rounded-xl text-sm font-medium transition-all whitespace-nowrap ${!categoryParam ? 'btn-primary' : 'btn-glass text-white/70 hover:text-white'}`}>
        Todas
      </a>
      {categories.map(cat => (
        <a
          href={`/?category=${cat}${searchParam ? `&search=${searchParam}` : ''}`}
          class={`px-4 py-2 rounded-xl text-sm font-medium transition-all whitespace-nowrap ${categoryParam === cat ? 'btn-primary' : 'btn-glass text-white/70 hover:text-white'}`}
        >
          {cat}
        </a>
      ))}
    </div>
  </div>

  <!-- Products Grid -->
  {error ? (
    <div class="glass-card p-8 text-center">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-red-500/10 mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
      </div>
      <p class="text-red-400 text-lg font-medium">Error al cargar productos</p>
      <p class="text-white/40 text-sm mt-2">{error.message}</p>
    </div>
  ) : products && products.length > 0 ? (
    <>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {products.map((product, i) => (
          <div style={`animation-delay: ${i * 0.1}s`}>
            <ProductCard
              id={product.id}
              title={product.title}
              price={product.price}
              imageUrl={product.image_url}
              category={product.category}
            />
          </div>
        ))}
      </div>

      <!-- Pagination -->
      {totalPages > 1 && (
        <div class="flex items-center justify-center gap-3 mt-12 animate-fade-in">
          <a
            href={currentPage > 1 ? `/?page=${currentPage - 1}${categoryParam ? `&category=${categoryParam}` : ''}${searchParam ? `&search=${searchParam}` : ''}` : '#'}
            class={`btn-glass px-5 py-2.5 rounded-xl text-sm flex items-center gap-2 ${currentPage <= 1 ? 'opacity-30 pointer-events-none' : 'text-white/80 hover:text-white'}`}
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            Anterior
          </a>

          <div class="flex gap-2">
            {Array.from({ length: totalPages }, (_, i) => i + 1).map(p => (
              <a
                href={`/?page=${p}${categoryParam ? `&category=${categoryParam}` : ''}${searchParam ? `&search=${searchParam}` : ''}`}
                class={`w-10 h-10 rounded-xl flex items-center justify-center text-sm font-medium transition-all ${
                  p === currentPage
                    ? 'btn-primary'
                    : 'btn-glass text-white/60 hover:text-white'
                }`}
              >
                {p}
              </a>
            ))}
          </div>

          <a
            href={currentPage < totalPages ? `/?page=${currentPage + 1}${categoryParam ? `&category=${categoryParam}` : ''}${searchParam ? `&search=${searchParam}` : ''}` : '#'}
            class={`btn-glass px-5 py-2.5 rounded-xl text-sm flex items-center gap-2 ${currentPage >= totalPages ? 'opacity-30 pointer-events-none' : 'text-white/80 hover:text-white'}`}
          >
            Siguiente
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        </div>
      )}
    </>
  ) : (
    <div class="glass-card p-16 text-center">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-white/5 mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><path d="m9 14 3-3 3 3"/></svg>
      </div>
      <h3 class="text-xl font-bold text-white/70 mb-2">Sin productos</h3>
      <p class="text-white/40">
        {searchParam
          ? `No se encontraron resultados para "${searchParam}".`
          : 'No hay productos en esta categoría.'}
      </p>
    </div>
  )}
</Layout>
