---
import Layout from '../layouts/Layout.astro';
import { getSupabase } from '../lib/supabase';

let errorMsg = '';

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const email = formData.get("email")?.toString();
  const password = formData.get("password")?.toString();

  if (email && password) {
    const supabase = getSupabase(Astro.cookies);
    const { error } = await supabase.auth.signInWithPassword({ email, password });
    if (error) {
      errorMsg = error.message;
    } else {
      return Astro.redirect("/admin");
    }
  } else {
    errorMsg = 'Por favor ingresa email y contraseña.';
  }
}
---

<Layout title="Iniciar Sesión">
  <div class="min-h-[70vh] flex items-center justify-center py-12">
    <div class="w-full max-w-sm animate-slide-up">
      <div class="glass-strong rounded-2xl p-7">
        <div class="text-center mb-6">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary to-accent flex items-center justify-center mx-auto mb-3 shadow-lg shadow-primary/30">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="12" cy="10" r="3"/><path d="M7 21v-2a3 3 0 0 1 3-3h4a3 3 0 0 1 3 3v2"/></svg>
          </div>
          <h2 class="text-xl font-semibold text-white/90">Iniciar Sesion</h2>
          <p class="text-white/30 text-xs mt-0.5">Accede a tu cuenta</p>
        </div>

        <!-- Tab Switcher -->
        <div class="flex mb-6 bg-white/[0.03] rounded-xl p-1">
          <button id="tab-customer" class="flex-1 py-2 text-xs font-medium rounded-lg transition-all">Cliente</button>
          <button id="tab-admin" class="flex-1 py-2 text-xs font-medium rounded-lg transition-all text-white/40">Administrador</button>
        </div>

        <!-- Customer Login Form (client-side) -->
        <div id="customer-form">
          <form id="login-form" class="space-y-4">
            <div>
              <label class="block text-xs font-medium text-white/40 mb-1.5">Email</label>
              <input type="email" id="login-email" required class="input-glass" placeholder="correo@ejemplo.com" />
            </div>
            <div>
              <label class="block text-xs font-medium text-white/40 mb-1.5">Contraseña</label>
              <input type="password" id="login-password" required class="input-glass" placeholder="••••••••" />
            </div>

            <div id="login-error" class="text-red-400 text-xs p-3 rounded-lg bg-red-500/10 border border-red-500/15 hidden"></div>

            <button type="submit" id="login-btn" class="btn-primary w-full py-2.5 rounded-lg font-medium text-sm">
              Ingresar
            </button>
          </form>

          <p class="text-center text-xs text-white/30 mt-4">
            ¿No tienes cuenta? <a href="/signup" class="text-primary-light hover:text-white transition-colors">Crear cuenta</a>
          </p>
        </div>

        <!-- Admin Login Form (server-side POST) -->
        <div id="admin-form" class="hidden">
          <form method="POST" class="space-y-4">
            <div>
              <label class="block text-xs font-medium text-white/40 mb-1.5">Email</label>
              <input type="email" name="email" required class="input-glass" placeholder="admin@ejemplo.com" />
            </div>
            <div>
              <label class="block text-xs font-medium text-white/40 mb-1.5">Contraseña</label>
              <input type="password" name="password" required class="input-glass" placeholder="••••••••" />
            </div>

            {errorMsg && (
              <div class="text-red-400 text-xs p-3 rounded-lg bg-red-500/10 border border-red-500/15 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><circle cx="12" cy="12" r="10"/><line x1="15" x2="9" y1="9" y2="15"/><line x1="9" x2="15" y1="9" y2="15"/></svg>
                {errorMsg}
              </div>
            )}

            <button type="submit" class="btn-primary w-full py-2.5 rounded-lg font-medium text-sm">
              Ingresar como Admin
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { login, getSession } from '../lib/auth';

    if (getSession()) window.location.href = '/';

    // Tab switching
    const tabCustomer = document.getElementById('tab-customer');
    const tabAdmin = document.getElementById('tab-admin');
    const customerForm = document.getElementById('customer-form');
    const adminForm = document.getElementById('admin-form');

    function setActiveTab(tab) {
      tabCustomer.className = `flex-1 py-2 text-xs font-medium rounded-lg transition-all ${tab === 'customer' ? 'bg-primary/20 text-white shadow-sm' : 'text-white/40 hover:text-white/70'}`;
      tabAdmin.className = `flex-1 py-2 text-xs font-medium rounded-lg transition-all ${tab === 'admin' ? 'bg-primary/20 text-white shadow-sm' : 'text-white/40 hover:text-white/70'}`;
      customerForm.classList.toggle('hidden', tab !== 'customer');
      adminForm.classList.toggle('hidden', tab !== 'admin');
    }

    tabCustomer?.addEventListener('click', () => setActiveTab('customer'));
    tabAdmin?.addEventListener('click', () => setActiveTab('admin'));

    // Customer login
    const form = document.getElementById('login-form');
    const btn = document.getElementById('login-btn') as HTMLButtonElement;
    const errorEl = document.getElementById('login-error');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      errorEl?.classList.add('hidden');

      const email = (document.getElementById('login-email') as HTMLInputElement).value.trim();
      const password = (document.getElementById('login-password') as HTMLInputElement).value;

      if (!email || !password) {
        if (errorEl) { errorEl.textContent = 'Ingresa email y contraseña'; errorEl.classList.remove('hidden'); }
        return;
      }

      const result = login(email, password);
      if (result.ok) {
        window.location.href = '/';
      } else {
        if (errorEl) { errorEl.textContent = result.error || 'Error al iniciar sesión'; errorEl.classList.remove('hidden'); }
      }
    });
  </script>
</Layout>
