---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Mi Perfil">
  <div class="max-w-4xl mx-auto py-8 animate-fade-in">
    <h1 class="text-2xl font-bold text-white/90 mb-8">Mi Perfil</h1>

    <div id="profile-logged-out" class="glass-card p-14 text-center">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-white/[0.03] mb-5">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </div>
      <h3 class="text-lg font-semibold text-white/60 mb-1">No has iniciado sesion</h3>
      <p class="text-white/30 text-sm mb-6">Inicia sesion para ver tu perfil y pedidos.</p>
      <a href="/login" class="btn-primary px-5 py-2.5 rounded-lg text-sm">Iniciar sesion</a>
    </div>

    <div id="profile-logged-in" class="hidden">
      <div class="glass-strong rounded-xl p-6 mb-8">
        <div class="flex items-center gap-4">
          <div class="w-14 h-14 rounded-full bg-gradient-to-br from-primary to-accent flex items-center justify-center text-white text-xl font-bold shadow-lg shadow-primary/30">
            <span id="profile-initial"></span>
          </div>
          <div>
            <h2 class="text-lg font-bold text-white/90" id="profile-name"></h2>
            <p class="text-sm text-white/40" id="profile-email"></p>
            <p class="text-xs text-white/20 mt-0.5" id="profile-date"></p>
          </div>
        </div>
      </div>

      <h3 class="text-lg font-bold text-white/80 mb-4">Mis pedidos</h3>
      <div id="profile-orders" class="space-y-3">
        <p class="text-white/20 text-sm text-center py-8">No has realizado ningun pedido.</p>
      </div>
    </div>
  </div>

  <script>
    import { getSession } from '../lib/auth';
    import { getOrders } from '../lib/cart';

    const session = getSession();

    if (!session) {
      document.getElementById('profile-logged-out')?.classList.remove('hidden');
      document.getElementById('profile-logged-in')?.classList.add('hidden');
    } else {
      document.getElementById('profile-logged-out')?.classList.add('hidden');
      document.getElementById('profile-logged-in')?.classList.remove('hidden');

      const initialEl = document.getElementById('profile-initial');
      const nameEl = document.getElementById('profile-name');
      const emailEl = document.getElementById('profile-email');
      const dateEl = document.getElementById('profile-date');

      if (initialEl) initialEl.textContent = session.name.charAt(0).toUpperCase();
      if (nameEl) nameEl.textContent = session.name;
      if (emailEl) emailEl.textContent = session.email;
      if (dateEl) dateEl.textContent = `Miembro desde ${new Date().toLocaleDateString('es-CO', { year: 'numeric', month: 'long' })}`;

      const orders = getOrders(session.id);
      const ordersEl = document.getElementById('profile-orders');

      if (orders.length === 0) {
        if (ordersEl) ordersEl.innerHTML = '<p class="text-white/20 text-sm text-center py-8">No has realizado ningun pedido.</p>';
      } else if (ordersEl) {
        ordersEl.innerHTML = orders.map(o => {
          const date = new Date(o.date);
          const dateStr = date.toLocaleDateString('es-CO', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
          const itemsSummary = o.items.map(i => `${i.title} × ${i.quantity}`).join(', ');
          const orderStatus = o.status || 'Confirmado';
          return `
            <div class="glass-card p-4">
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1 min-w-0">
                  <p class="text-xs text-white/30">${dateStr}</p>
                  <p class="text-sm text-white/80 mt-0.5">${itemsSummary}</p>
                </div>
                <div class="text-right shrink-0">
                  <p class="text-sm font-bold text-gradient-primary">$${o.total.toFixed(2)}</p>
                  <span class="tag text-[9px]">${orderStatus}</span>
                </div>
              </div>
            </div>
          `;
        }).join('');
      }
    }
    addEventListener('orders-update', () => {
      const s = getSession();
      if (s) {
        const orders = getOrders(s.id);
        const ordersEl = document.getElementById('profile-orders');
        if (orders.length === 0) {
          if (ordersEl) ordersEl.innerHTML = '<p class="text-white/20 text-sm text-center py-8">No has realizado ningun pedido.</p>';
        } else if (ordersEl) {
          ordersEl.innerHTML = orders.map(o => {
            const date = new Date(o.date);
            const dateStr = date.toLocaleDateString('es-CO', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
            const itemsSummary = o.items.map(i => `${i.title} × ${i.quantity}`).join(', ');
            const orderStatus = o.status || 'Confirmado';
            return `
              <div class="glass-card p-4">
                <div class="flex items-start justify-between gap-4">
                  <div class="flex-1 min-w-0">
                    <p class="text-xs text-white/30">${dateStr}</p>
                    <p class="text-sm text-white/80 mt-0.5">${itemsSummary}</p>
                  </div>
                  <div class="text-right shrink-0">
                    <p class="text-sm font-bold text-gradient-primary">$${o.total.toFixed(2)}</p>
                    <span class="tag text-[9px]">${orderStatus}</span>
                  </div>
                </div>
              </div>
            `;
          }).join('');
        }
      }
    });
  </script>
</Layout>
