---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacto">
  <div class="max-w-2xl mx-auto py-8 animate-fade-in text-center">
    <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary to-accent flex items-center justify-center mx-auto mb-4 shadow-lg shadow-primary/30">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
    </div>
    <h1 class="text-2xl font-bold text-white/90 mb-2">Contacto</h1>
    <p class="text-white/40 text-sm mb-8">Escribenos y te responderemos a la brevedad.</p>

    <div class="glass-strong rounded-2xl p-6 text-left">
      <form id="contact-form" class="space-y-4">
        <div>
          <label class="block text-xs font-medium text-white/40 mb-1.5">Nombre</label>
          <input type="text" id="contact-name" class="input-glass" placeholder="Tu nombre" required />
        </div>
        <div>
          <label class="block text-xs font-medium text-white/40 mb-1.5">Email</label>
          <input type="email" id="contact-email" class="input-glass" placeholder="tu@correo.com" required />
        </div>
        <div>
          <label class="block text-xs font-medium text-white/40 mb-1.5">Mensaje</label>
          <textarea id="contact-msg" rows="4" class="input-glass resize-none" placeholder="Escribe tu mensaje..." required></textarea>
        </div>
        <div id="contact-success" class="text-green-400 text-xs p-3 rounded-lg bg-green-500/10 border border-green-500/15 hidden">
          Mensaje enviado con exito. Te responderemos pronto.
        </div>
        <button type="submit" class="btn-primary w-full py-2.5 rounded-lg font-medium text-sm">Enviar mensaje</button>
      </form>
    </div>
  </div>

  <script>
    const form = document.getElementById('contact-form');
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const successEl = document.getElementById('contact-success');
      const inputs = form.querySelectorAll('input, textarea');
      inputs.forEach(i => (i as HTMLInputElement).value = '');
      if (successEl) {
        successEl.classList.remove('hidden');
        setTimeout(() => successEl.classList.add('hidden'), 4000);
      }
    });
  </script>
</Layout>
