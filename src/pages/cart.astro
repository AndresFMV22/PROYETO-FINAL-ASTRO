---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Carrito de Compras">
  <div class="max-w-4xl mx-auto py-8 animate-fade-in">
    <h1 class="text-2xl font-bold text-white/90 mb-8">Carrito de Compras</h1>

    <div id="cart-empty" class="glass-card p-14 text-center hidden">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-white/[0.03] mb-5">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
      </div>
      <h3 class="text-lg font-semibold text-white/60 mb-1">Tu carrito está vacío</h3>
      <p class="text-white/30 text-sm mb-6">Agrega productos desde el catálogo</p>
      <a href="/" class="btn-primary px-5 py-2.5 rounded-lg text-sm">Ir al catálogo</a>
    </div>

    <div id="cart-content" class="hidden">
      <div id="cart-items" class="space-y-4 mb-8"></div>

      <div class="glass-strong rounded-xl p-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div>
          <p class="text-white/40 text-xs uppercase tracking-wider font-medium">Total</p>
          <p class="text-3xl font-bold text-gradient-primary" id="cart-total">$0.00</p>
        </div>
        <div class="flex items-center gap-3">
          <button onclick="clearCart()" class="btn-glass px-5 py-2.5 rounded-lg text-xs text-red-400/70 hover:text-red-400">Vaciar carrito</button>
          <button onclick="showPayment()" class="btn-primary px-5 py-2.5 rounded-lg text-xs">Proceder al pago</button>
        </div>
      </div>
    </div>

    <!-- Payment Modal -->
    <div id="payment-overlay" class="fixed inset-0 z-[100] flex items-center justify-center p-4 hidden">
      <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="hidePayment()"></div>
      <div class="glass-strong rounded-2xl p-6 md:p-8 w-full max-w-md relative z-10 animate-slide-up">
        <button onclick="hidePayment()" class="absolute top-4 right-4 text-white/30 hover:text-white/60 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>

        <div id="payment-form">
          <div class="text-center mb-6">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary to-accent flex items-center justify-center mx-auto mb-3 shadow-lg shadow-primary/30">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
            </div>
            <h2 class="text-lg font-bold text-white/90">Pago seguro</h2>
            <p class="text-white/30 text-xs mt-0.5">Completa tus datos para procesar el pago</p>
          </div>

          <div class="space-y-4">
            <div>
              <label class="block text-xs font-medium text-white/40 mb-1.5">Nombre del titular</label>
              <input type="text" id="card-name" class="input-glass" placeholder="Juan Pérez" autocomplete="off" />
            </div>
            <div>
              <label class="block text-xs font-medium text-white/40 mb-1.5">Número de tarjeta</label>
              <input type="text" id="card-number" class="input-glass" placeholder="4242 4242 4242 4242" maxlength="19" autocomplete="off" />
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-medium text-white/40 mb-1.5">Fecha de expiración</label>
                <input type="text" id="card-expiry" class="input-glass" placeholder="MM/AA" maxlength="5" autocomplete="off" />
              </div>
              <div>
                <label class="block text-xs font-medium text-white/40 mb-1.5">CVV</label>
                <input type="text" id="card-cvv" class="input-glass" placeholder="123" maxlength="4" autocomplete="off" />
              </div>
            </div>

            <div class="flex items-center gap-2 text-white/25 text-xs pt-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <span>Pago simulado — sin cargo real</span>
            </div>

            <div id="payment-error" class="text-xs p-3 rounded-lg bg-red-500/10 text-red-400 border border-red-500/15 hidden"></div>

            <button id="pay-btn" onclick="processPayment()" class="btn-primary w-full py-3 rounded-lg font-medium text-sm flex items-center justify-center gap-2 disabled:opacity-50">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 0 0-4 4v4h8V6a4 4 0 0 0-4-4Z"/><path d="M2 12h20v4a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4v-4Z"/><path d="M6 16v-2"/><path d="M18 16v-2"/></svg>
              Pagar <span id="pay-amount"></span>
            </button>
          </div>
        </div>

        <div id="payment-success" class="hidden text-center py-6">
          <div class="w-16 h-16 rounded-full bg-green-500/15 flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          </div>
          <h2 class="text-xl font-bold text-white/90 mb-1">¡Pago exitoso! 🎉</h2>
          <p class="text-white/40 text-sm mb-6">Tu pedido ha sido confirmado correctamente.</p>
          <div class="glass rounded-xl p-4 mb-6 text-left space-y-1.5">
            <p class="text-xs text-white/30">Resumen del pedido</p>
            <div id="success-items" class="text-sm text-white/70 space-y-1"></div>
            <div class="border-t border-white/[0.06] pt-2 mt-2 flex justify-between">
              <span class="text-xs text-white/40">Total pagado</span>
              <span class="text-sm font-bold text-gradient-primary" id="success-total"></span>
            </div>
          </div>
          <a href="/" class="btn-primary px-6 py-2.5 rounded-lg text-sm">Volver al catálogo</a>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { getItems, removeItem, updateQuantity, clearCart as clearCartFn, getTotalPrice, addOrder } from '../lib/cart';
    import { getSession } from '../lib/auth';
    import { createBrowserClient } from '@supabase/ssr';

    const supabase = createBrowserClient(
      import.meta.env.PUBLIC_SUPABASE_URL,
      import.meta.env.PUBLIC_SUPABASE_ANON_KEY
    );

    const stockCache: Record<string, number> = {};

    try {
      const session = getSession();
      const key = session?.id ? `liquidsky-cart-${session.id}` : 'liquidsky-cart';
      console.log('[CartPage] Usuario:', session?.id || 'invitado', '| Key:', key);
      console.log('[CartPage] Cart raw:', localStorage.getItem(key));
      console.log('[CartPage] getItems() retorna:', JSON.stringify(getItems()));
    } catch (_) {}

    async function loadStock(items: { id: string }[]) {
      const ids = items.map(i => i.id);
      if (ids.length === 0) return;
      const { data } = await supabase.from('products').select('id, stock').in('id', ids);
      if (data) {
        data.forEach(p => { stockCache[p.id] = p.stock ?? 10; });
      }
    }

    async function render() {
      const items = getItems();
      const emptyEl = document.getElementById('cart-empty');
      const contentEl = document.getElementById('cart-content');
      const itemsEl = document.getElementById('cart-items');
      const totalEl = document.getElementById('cart-total');

      if (items.length === 0) {
        emptyEl?.classList.remove('hidden');
        contentEl?.classList.add('hidden');
        return;
      }

      emptyEl?.classList.add('hidden');
      contentEl?.classList.remove('hidden');

      await loadStock(items);

      if (itemsEl) {
        itemsEl.innerHTML = items.map(item => {
          const maxStock = stockCache[item.id] ?? 10;
          const atMax = item.quantity >= maxStock;
          return `
          <div class="glass-card p-4 flex items-center gap-4" data-id="${item.id}">
            <div class="w-16 h-16 rounded-xl bg-white/[0.03] overflow-hidden shrink-0">
              ${item.imageUrl
                ? `<img src="${item.imageUrl}" alt="${item.title}" class="w-full h-full object-cover"/>`
                : '<div class="w-full h-full flex items-center justify-center text-white/10"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg></div>'}
            </div>
            <div class="flex-1 min-w-0">
              <a href="/product/${item.id}" class="text-sm font-medium text-white/80 hover:text-white transition-colors truncate block">${item.title}</a>
              <p class="text-sm font-semibold text-gradient-primary mt-0.5">$${(item.price * item.quantity).toFixed(2)}</p>
              <p class="text-[10px] text-white/20 mt-0.5">Stock: ${maxStock}${atMax ? ' <span class="text-amber-400">(max)</span>' : ''}</p>
            </div>
            <div class="flex items-center gap-2">
              <div class="flex items-center gap-1 bg-white/[0.04] rounded-lg p-0.5">
                <button onclick="decQty('${item.id}')" class="w-7 h-7 rounded-md flex items-center justify-center text-white/40 hover:text-white hover:bg-white/10 transition-all text-sm">−</button>
                <span class="w-6 text-center text-sm font-medium text-white/80">${item.quantity}</span>
                <button onclick="incQty('${item.id}')" ${atMax ? 'disabled' : ''} class="w-7 h-7 rounded-md flex items-center justify-center text-white/40 hover:text-white hover:bg-white/10 transition-all text-sm ${atMax ? 'opacity-30 cursor-not-allowed' : ''}">+</button>
              </div>
              <button onclick="removeItem('${item.id}')" class="p-1.5 rounded-lg text-red-400/50 hover:text-red-400 hover:bg-red-500/10 transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
              </button>
            </div>
          </div>
        `}).join('');
      }

      if (totalEl) {
        totalEl.textContent = `$${getTotalPrice().toFixed(2)}`;
      }
    }

    (window as any).incQty = (id: string) => {
      const items = getItems();
      const item = items.find(i => i.id === id);
      if (item) {
        const maxStock = stockCache[id] ?? 10;
        if (item.quantity >= maxStock) {
          showError(`Stock maximo disponible: ${maxStock}`);
          return;
        }
        updateQuantity(id, item.quantity + 1);
      }
      render();
    };

    (window as any).decQty = (id: string) => {
      const items = getItems();
      const item = items.find(i => i.id === id);
      if (item && item.quantity > 1) updateQuantity(id, item.quantity - 1);
      else removeItem(id);
      render();
    };

    (window as any).removeItem = (id: string) => {
      removeItem(id);
      render();
    };

    (window as any).clearCart = () => {
      clearCartFn();
      render();
    };

    // --- Payment ---

    (window as any).showPayment = () => {
      const overlay = document.getElementById('payment-overlay');
      const amountEl = document.getElementById('pay-amount');
      const formEl = document.getElementById('payment-form');
      const successEl = document.getElementById('payment-success');
      const errorEl = document.getElementById('payment-error');

      overlay?.classList.remove('hidden');
      formEl?.classList.remove('hidden');
      successEl?.classList.add('hidden');
      errorEl?.classList.add('hidden');

      if (amountEl) {
        amountEl.textContent = `$${getTotalPrice().toFixed(2)}`;
      }

      (document.getElementById('card-name') as HTMLInputElement).value = '';
      (document.getElementById('card-number') as HTMLInputElement).value = '';
      (document.getElementById('card-expiry') as HTMLInputElement).value = '';
      (document.getElementById('card-cvv') as HTMLInputElement).value = '';

      const payBtn = document.getElementById('pay-btn') as HTMLButtonElement;
      if (payBtn) payBtn.disabled = false;
    };

    (window as any).hidePayment = () => {
      document.getElementById('payment-overlay')?.classList.add('hidden');
    };

    // Format card number with spaces
    document.getElementById('card-number')?.addEventListener('input', (e) => {
      const input = e.target as HTMLInputElement;
      let val = input.value.replace(/\D/g, '').substring(0, 16);
      val = val.replace(/(\d{4})(?=\d)/g, '$1 ');
      input.value = val;
    });

    // Format expiry
    document.getElementById('card-expiry')?.addEventListener('input', (e) => {
      const input = e.target as HTMLInputElement;
      let val = input.value.replace(/\D/g, '').substring(0, 4);
      if (val.length > 2) val = val.substring(0, 2) + '/' + val.substring(2);
      input.value = val;
    });

    // CVV only numbers
    document.getElementById('card-cvv')?.addEventListener('input', (e) => {
      const input = e.target as HTMLInputElement;
      input.value = input.value.replace(/\D/g, '').substring(0, 4);
    });

    (window as any).processPayment = async () => {
      const name = (document.getElementById('card-name') as HTMLInputElement).value.trim();
      const number = (document.getElementById('card-number') as HTMLInputElement).value.replace(/\s/g, '');
      const expiry = (document.getElementById('card-expiry') as HTMLInputElement).value.trim();
      const cvv = (document.getElementById('card-cvv') as HTMLInputElement).value.trim();
      const errorEl = document.getElementById('payment-error');
      const payBtn = document.getElementById('pay-btn') as HTMLButtonElement;

      errorEl?.classList.add('hidden');

      if (!name) { showError('Ingresa el nombre del titular'); return; }
      if (number.length < 16) { showError('Ingresa un número de tarjeta válido'); return; }
      if (expiry.length < 5) { showError('Ingresa una fecha de expiración válida'); return; }
      if (cvv.length < 3) { showError('Ingresa un CVV válido'); return; }

      if (payBtn) {
        payBtn.disabled = true;
        payBtn.innerHTML = '<svg class="animate-spin -ml-1 mr-1.5 h-4 w-4 text-white inline" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Procesando pago...';
      }

      const items = getItems();
      const total = getTotalPrice();

      // Validar stock contra Supabase antes de procesar
      const ids = items.map(i => i.id);
      const { data: stockData } = await supabase.from('products').select('id, stock').in('id', ids);
      if (stockData) {
        for (const item of items) {
          const dbStock = stockData.find(p => p.id === item.id)?.stock ?? 0;
          if (item.quantity > dbStock) {
            showError(`Stock insuficiente para "${item.title}". Disponible: ${dbStock}, en tu carrito: ${item.quantity}`);
            if (payBtn) { payBtn.disabled = false; payBtn.innerHTML = 'Pagar <span id="pay-amount"></span>'; }
            return;
          }
        }
      }

      await new Promise(r => setTimeout(r, 2000));

      // Decrementar stock en Supabase
      for (const item of items) {
        const current = stockData?.find(p => p.id === item.id)?.stock ?? 0;
        await supabase.from('products').update({ stock: current - item.quantity }).eq('id', item.id);
      }

      const formEl = document.getElementById('payment-form');
      const successEl = document.getElementById('payment-success');
      const successItemsEl = document.getElementById('success-items');
      const successTotalEl = document.getElementById('success-total');

      formEl?.classList.add('hidden');
      successEl?.classList.remove('hidden');

      if (successItemsEl) {
        successItemsEl.innerHTML = items.map(i =>
          `<div class="flex justify-between"><span>${i.title} × ${i.quantity}</span><span>$${(i.price * i.quantity).toFixed(2)}</span></div>`
        ).join('');
      }
      if (successTotalEl) successTotalEl.textContent = `$${total.toFixed(2)}`;

      addOrder(items, total, name);
      clearCartFn();
      render();

      if (payBtn) payBtn.innerHTML = 'Pagado';
    };

    function showError(msg: string) {
      const el = document.getElementById('payment-error');
      if (el) {
        el.textContent = msg;
        el.classList.remove('hidden');
      }
    }

    addEventListener('cart-update', render);
    render();
  </script>
</Layout>
