---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Carrito de Compras">
  <div class="max-w-4xl mx-auto py-8 animate-fade-in">
    <h1 class="text-2xl font-bold text-white/90 mb-8">Carrito de Compras</h1>

    <div id="cart-empty" class="glass-card p-14 text-center hidden">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-white/[0.03] mb-5">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
      </div>
      <h3 class="text-lg font-semibold text-white/60 mb-1">Tu carrito está vacío</h3>
      <p class="text-white/30 text-sm mb-6">Agrega productos desde el catálogo</p>
      <a href="/" class="btn-primary px-5 py-2.5 rounded-lg text-sm">Ir al catálogo</a>
    </div>

    <div id="cart-content" class="hidden">
      <div id="cart-items" class="space-y-4 mb-8"></div>

      <div class="glass-strong rounded-xl p-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div>
          <p class="text-white/40 text-xs uppercase tracking-wider font-medium">Total</p>
          <p class="text-3xl font-bold text-gradient-primary" id="cart-total">$0.00</p>
        </div>
        <button onclick="clearCart()" class="btn-glass px-5 py-2.5 rounded-lg text-xs text-red-400/70 hover:text-red-400">Vaciar carrito</button>
      </div>
    </div>
  </div>

  <script>
    import { getItems, removeItem, updateQuantity, clearCart as clearCartFn, getTotalPrice } from '../lib/cart';

    function render() {
      const items = getItems();
      const emptyEl = document.getElementById('cart-empty');
      const contentEl = document.getElementById('cart-content');
      const itemsEl = document.getElementById('cart-items');
      const totalEl = document.getElementById('cart-total');

      if (items.length === 0) {
        emptyEl?.classList.remove('hidden');
        contentEl?.classList.add('hidden');
        return;
      }

      emptyEl?.classList.add('hidden');
      contentEl?.classList.remove('hidden');

      if (itemsEl) {
        itemsEl.innerHTML = items.map(item => `
          <div class="glass-card p-4 flex items-center gap-4" data-id="${item.id}">
            <div class="w-16 h-16 rounded-xl bg-white/[0.03] overflow-hidden shrink-0">
              ${item.imageUrl
                ? `<img src="${item.imageUrl}" alt="${item.title}" class="w-full h-full object-cover"/>`
                : '<div class="w-full h-full flex items-center justify-center text-white/10"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg></div>'}
            </div>
            <div class="flex-1 min-w-0">
              <a href="/product/${item.id}" class="text-sm font-medium text-white/80 hover:text-white transition-colors truncate block">${item.title}</a>
              <p class="text-sm font-semibold text-gradient-primary mt-0.5">$${(item.price * item.quantity).toFixed(2)}</p>
            </div>
            <div class="flex items-center gap-2">
              <div class="flex items-center gap-1 bg-white/[0.04] rounded-lg p-0.5">
                <button onclick="decQty('${item.id}')" class="w-7 h-7 rounded-md flex items-center justify-center text-white/40 hover:text-white hover:bg-white/10 transition-all text-sm">−</button>
                <span class="w-6 text-center text-sm font-medium text-white/80">${item.quantity}</span>
                <button onclick="incQty('${item.id}')" class="w-7 h-7 rounded-md flex items-center justify-center text-white/40 hover:text-white hover:bg-white/10 transition-all text-sm">+</button>
              </div>
              <button onclick="removeItem('${item.id}')" class="p-1.5 rounded-lg text-red-400/50 hover:text-red-400 hover:bg-red-500/10 transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
              </button>
            </div>
          </div>
        `).join('');
      }

      if (totalEl) {
        totalEl.textContent = `$${getTotalPrice().toFixed(2)}`;
      }
    }

    (window as any).incQty = (id: string) => {
      const items = getItems();
      const item = items.find(i => i.id === id);
      if (item) updateQuantity(id, item.quantity + 1);
      render();
    };

    (window as any).decQty = (id: string) => {
      const items = getItems();
      const item = items.find(i => i.id === id);
      if (item && item.quantity > 1) updateQuantity(id, item.quantity - 1);
      else removeItem(id);
      render();
    };

    (window as any).removeItem = (id: string) => {
      removeItem(id);
      render();
    };

    (window as any).clearCart = () => {
      clearCartFn();
      render();
    };

    addEventListener('cart-update', render);
    render();
  </script>
</Layout>
