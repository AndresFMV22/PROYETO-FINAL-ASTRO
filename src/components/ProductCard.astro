---
interface Props {
  id: string;
  title: string;
  price: number;
  imageUrl?: string;
  category: string;
}

const { id, title, price, imageUrl, category } = Astro.props;
---

<a
  href={`/product/${id}`}
  class="group glass-card block overflow-hidden animate-fade-in"
>
  <div class="aspect-square w-full overflow-hidden relative">
    {imageUrl ? (
      <img
        src={imageUrl}
        alt={title}
        class="h-full w-full object-cover transition-all duration-700 group-hover:scale-105"
        loading="lazy"
      />
    ) : (
      <div class="h-full w-full flex items-center justify-center" style="color: rgba(255,255,255,0.15);">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
      </div>
    )}
    <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
    <div class="absolute top-3 right-3 tag">
      {category}
    </div>
  </div>
  <div class="p-4">
    <h3 class="font-medium text-sm text-white/80 truncate group-hover:text-white transition-colors" title={title}>{title}</h3>
    <p class="mt-1.5 text-lg font-semibold text-primary tracking-tight">${price.toFixed(2)}</p>
  </div>
</a>
