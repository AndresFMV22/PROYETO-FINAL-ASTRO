---
import '../styles/global.css';
import AmbientBackground from '../components/AmbientBackground.astro';

interface Props {
  title?: string;
}

const { title = "Admin - LiquidSky" } = Astro.props;
---

<!DOCTYPE html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="relative">
    <AmbientBackground />
    <div class="relative z-10 min-h-screen">
      <header class="sticky top-0 z-50 glass border-b border-white/[0.04]">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-14 flex items-center justify-between">
          <a href="/" class="flex items-center gap-2.5 group">
            <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-primary to-accent flex items-center justify-center group-hover:scale-110 transition-transform shadow-lg shadow-primary/30">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 0 0-4 4v4h8V6a4 4 0 0 0-4-4Z"/><path d="M2 12h20v4a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4v-4Z"/><path d="M6 16v-2"/><path d="M18 16v-2"/></svg>
            </div>
            <span class="text-base font-semibold text-white/80 group-hover:text-white transition-colors">LiquidSky</span>
          </a>
          <div class="flex items-center gap-2">
            <a href="/admin/products" class="btn-glass px-3.5 py-1.5 rounded-lg text-xs">Productos</a>
            <a href="/admin/logout" class="btn-glass px-3.5 py-1.5 rounded-lg text-xs text-red-400/70 hover:text-red-400">Salir</a>
          </div>
        </nav>
      </header>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <h1 class="text-2xl font-bold text-white/90 mb-6">{title}</h1>
        <slot />
      </div>

      <footer class="border-t border-white/[0.04] mt-20 py-6">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
          <p class="text-white/20 text-xs">&copy; {new Date().getFullYear()} LiquidSky Admin Panel</p>
        </div>
      </footer>
    </div>
  </body>
</html>
